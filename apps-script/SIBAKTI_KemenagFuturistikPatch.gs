 careerPlan:{sheet:'41_RencanaKarier',idField:'KarierID',headers:['KarierID','StudentID','NISN','MinatKarier','BidangKarier','HasilRIASEC','KekuatanDiri','KelemahanDiri','RencanaJangkaPendek','RencanaJangkaPanjang','RekomendasiPekerjaan','RekomendasiJurusan','StatusValidasi','CreatedBy','ValidatedBy','CreatedAt','UpdatedAt']},
