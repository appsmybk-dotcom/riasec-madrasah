 academic:{sheet:'31_PortofolioAkademik',idField:'AkademikID',headers:['AkademikID','StudentID','NISN','Semester','TahunAjaran','Mapel','NilaiPengetahuan','NilaiKeterampilan','NilaiAkhir','Predikat','Catatan','StatusValidasi','CreatedBy','ValidatedBy','CreatedAt','UpdatedAt']},
